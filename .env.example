# Loam web app environment. Copy to .env.local and fill in.
# Never commit real values. .env*.local is gitignored.

# Supabase project (loam)
NEXT_PUBLIC_SUPABASE_URL=https://eszxpusqgwwcyndzjzot.supabase.co

# Publishable / anon key (client-safe). Get it from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SERVER ONLY, never exposed to the browser).
# Used by server components to read your data before auth is wired up.
SUPABASE_SERVICE_ROLE_KEY=
